{
    "name": "dqx-chat-manager",
    "productName": "DQX Chat Manager",
    "description": "DQX Chat Manager",
    "version": "0.1.19",
    "license": "MIT",
    "author": {
        "name": "tubame0505"
    },
    "main": "dist/main.js",
    "scripts": {
        "compile": "tsc -p tsconfig.main.json && cross-env NODE_ENV=\"development\" NO_WATCH=\"true\" webpack",
        "build": "cross-env NODE_ENV=\"production\" webpack --progress && cpx node_modules/regedit/vbs/* dist/vbs",
        "buildwin": "electron-packager . DQXChatManager --platform=win32 --arch=x64 --overwrite --ignore='src' --ignore 'node_modules' --ignore='.vscode' --ignore='media' --out=packages",
        "dev": "run-p dev:*",
        "predev": "rimraf dist",
        "dev:tsc": "tsc -w -p tsconfig.main.json",
        "dev:webpack": "cross-env NODE_ENV=\"development\" webpack --progress",
        "dev:electron": "node scripts/wait-for-file.js ./dist/index.html && cross-env NODE_ENV=\"development\" electron ."
    },
    "dependencies": {
        "compressing": "^2.1.1",
        "punycode": "^2.3.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "regedit": "^5.1.4",
        "selenium-webdriver": "^4.43.0"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/request": "^2.48.13",
        "@types/selenium-webdriver": "^4.35.5",
        "@typescript-eslint/eslint-plugin": "^8.58.2",
        "@typescript-eslint/parser": "^8.58.2",
        "cpx2": "^8.0.2",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "electron": "^41.2.0",
        "electron-packager": "^17.1.2",
        "electron-reload": "^2.0.0-alpha.1",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "html-webpack-plugin": "^5.6.6",
        "mini-css-extract-plugin": "^2.10.2",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "ts-loader": "^9.5.7",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "webpack": "^5.106.2",
        "webpack-cli": "^7.0.2"
    }
}